# AI Provider Gateway - Environment Configuration Example
# Copy this file to .env and modify as needed

# =============================================================================
# Provider Settings
# =============================================================================

# AI provider to use: ollama | openai
AI_PROVIDER=ollama

# Default model name
AI_MODEL=gemma3:1b

# =============================================================================
# Ollama Settings
# =============================================================================

# Ollama API base URL
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# OpenAI Settings (for future use)
# =============================================================================

# OpenAI API Key
# OPENAI_API_KEY=sk-...

# OpenAI API base URL (optional, for compatible APIs)
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Request Settings
# =============================================================================

# HTTP request timeout in seconds
REQUEST_TIMEOUT_SECONDS=30

# =============================================================================
# Logging Settings
# =============================================================================

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Service Metadata
# =============================================================================

# Service version (shown in /health response)
SERVICE_VERSION=0.1.0
